{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "rewrites": [
    { "source": "/dashboard", "destination": "/dashboard.php" },
    { "source": "/dashboard/(.*)", "destination": "/dashboard.php" },

    { "source": "/api/(.*)", "destination": "/api/$1.php" },

    { "source": "/(.*)\\.png$", "destination": "/$1.png" },

    { "source": "/(.*)", "destination": "/index.php" }
  ]
}
