{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "dashboard.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "index.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "check_enroll_status.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "update_status.php": {
      "runtime": "vercel-php@0.7.1"
    }
    // Tambahkan file PHP lain yang kamu pakai di sini jika ada
  },
  "rewrites": [
    { "source": "/dashboard", "destination": "/dashboard.php" },
    { "source": "/dashboard/(.*)", "destination": "/dashboard.php" },

    { "source": "/api/(.*)", "destination": "/api/$1.php" },

    { "source": "/(.*)\\.png$", "destination": "/$1.png" },

    { "source": "/(.*)", "destination": "/index.php" }
  ]
}
